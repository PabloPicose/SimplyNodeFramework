{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": true,
        "SNF_EXPERIMENTAL": false
      }
    },
    {
      "name": "native-debug",
      "displayName": "Native Debug",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SNF_ENABLE_TESTS": true,
        "SNF_WEB_ASSEMBLY": false,
        "SNF_ENABLE_SQLITE": true,
        "SNF_ENABLE_PROFILING": true
        "SNF_ENABLE_MYSQL": true,
        "SNF_ENABLE_SNMP": false
      }
    },
    {
      "name": "native-release",
      "displayName": "Native Release",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SNF_ENABLE_TESTS": true,
        "SNF_WEB_ASSEMBLY": false,
        "SNF_ENABLE_SQLITE": true,
        "SNF_ENABLE_MYSQL": true,
        "SNF_ENABLE_SNMP": false
      }
    },
    {
      "name": "actions",
      "displayName": "GitHub Actions",
      "inherits": "native-debug",
      "binaryDir": "${sourceDir}/build/actions",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SNF_ENABLE_TESTS": true,
        "SNF_WEB_ASSEMBLY": false,
        "SNF_ENABLE_SQLITE": true,
        "SNF_ENABLE_MYSQL": true,
        "SNF_ENABLE_SNMP": false
      }
    },
    {
      "name": "native-debug-experimental",
      "displayName": "Native Debug Experimental",
      "inherits": "native-debug",
      "binaryDir": "${sourceDir}/build/debug-experimental",
      "cacheVariables": {
        "SNF_EXPERIMENTAL": true
      }
    },
    {
      "name": "web-debug",
      "displayName": "Web Debug - Emscripten",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/web-debug",
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "SNF_WEB_ASSEMBLY": true,
        "SNF_ENABLE_SQLITE": false,
        "SNF_ENABLE_TESTS": false
      }
    },
    {
      "name": "web-release",
      "displayName": "Web Release - Emscripten",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/web-release",
      "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "SNF_WEB_ASSEMBLY": true,
        "SNF_ENABLE_SQLITE": false,
        "SNF_ENABLE_TESTS": false
      }
    }
  ],
  "buildPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug"
    },
    {
      "name": "actions",
      "configurePreset": "actions"
    },
    {
      "name": "native-release",
      "configurePreset": "native-release"
    },
    {
      "name": "native-debug-experimental",
      "configurePreset": "native-debug-experimental"
    },
    {
      "name": "web-debug",
      "configurePreset": "web-debug"
    },
    {
      "name": "web-release",
      "configurePreset": "web-release"
    }
  ],
  "testPresets": [
    {
      "name": "native-debug",
      "configurePreset": "native-debug",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 2,
        "timeout": 60
      }
    },
    {
      "name": "native-release",
      "configurePreset": "native-release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 2,
        "timeout": 60
      }
    },
    {
      "name": "actions",
      "configurePreset": "actions",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 4,
        "timeout": 60
      }
    },
    {
      "name": "native-debug-experimental",
      "configurePreset": "native-debug-experimental",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "jobs": 2,
        "timeout": 60
      }
    }
  ]
}

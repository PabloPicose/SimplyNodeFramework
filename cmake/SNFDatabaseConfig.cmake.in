@PACKAGE_INIT@

include(CMakeFindDependencyMacro)
find_dependency(SNFCore CONFIG REQUIRED)
if(@SNF_ENABLE_SQLITE@)
    find_dependency(SQLite3 REQUIRED)
endif()
if(@SNF_ENABLE_MYSQL@)
    find_dependency(PkgConfig REQUIRED)
    pkg_check_modules(MYSQLCLIENT REQUIRED IMPORTED_TARGET mysqlclient)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/SNFDatabaseTargets.cmake")

if(TARGET SNFDatabase AND NOT TARGET SNFDatabase::SNFDatabase)
    add_library(SNFDatabase::SNFDatabase ALIAS SNFDatabase)
endif()

check_required_components(SNFDatabase)
